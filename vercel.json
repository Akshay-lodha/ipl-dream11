{
  "version": 2,
  "buildCommand": null,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/logos/(.*)", "dest": "/public/logos/$1" },
    { "src": "/(.*)",      "dest": "/public/$1" }
  ]
}
